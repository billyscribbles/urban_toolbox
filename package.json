{
  "name": "foundation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/gen-seo-files.mjs",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
