# Formspree form ID for the /quote request form (https://formspree.io).
VITE_FORMSPREE_ID=your_formspree_form_id_here

# Production site URL. Used for canonical/OG tags and to template
# public/sitemap.xml + public/robots.txt at build time.
VITE_SITE_URL=https://example.com

# Optional. Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank to ship no analytics.
VITE_GA_ID=

# Optional. Google Tag Manager container ID (e.g. GTM-XXXXXXX).
# Loads the GTM container (Google Ads / remarketing tags). Leave blank to skip.
VITE_GTM_ID=

# Optional. Sentry DSN. Leave blank to ship no error monitoring.
# To enable: see README "Error monitoring".
VITE_SENTRY_DSN=
